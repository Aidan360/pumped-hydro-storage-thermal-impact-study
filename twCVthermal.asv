%{
no flow considerations:
River temp does not matter, data can be assumed for now for heat exchange
heat exchange in resivour 

%}
function out = noFlowCondition(depth,Tair,Wz,riverDischarge,lT,uT,resV,Cp,rMR,rMD,riverV,solarRad,rH)
    %Preliminary Area Calculations
    resArea = resAreaCalc(depth,rMR,rMD);
    riverCrossArea = riverDischarge / riverV; % modeling river as cylinder 
    riverDia = 2*sqrt(riverCrossArea/pi); % river dia, assume river surface area is 1m x river dia area square.
    riverSA = riverDia;
    
    %Surface Heat Transfer
 %   disp("Upper exchange")
    duT = surfaceHeatTransfer(solarRad,Tair,uT,Wz,Cp,resArea,resV,rH); % [°C]
  %  disp("Lower Exchange")
    dlT =  surfaceHeatTransfer(solarRad,Tair,lT,Wz,Cp,riverSA,riverCrossArea,rH);
    %Heat Exchange
    reT = lT + duT; % new res temp
    riT = uT + dlT; % new river temp
    out = [reT,riT];
end


function out = flowCondition(depth,Tair,Wz,riverDischarge,lT,uT,resV,Cp,rMR,rMD,riverV,solarRad,rH, ...
    flowRate,turbHeatCoff,pumpHeatCoff)
    %disp(["flowRate: ", flowRate])
    %Area Calculations
    newDepth = resDepthCalc(flowRate,depth,rMR,rMD);
    resArea = resAreaCalc(newDepth,rMR,rMD);
    newResV = resV + flowRate*15*60; %considering 15 minute intervals

    riverCrossArea = (riverDischarge-flowRate) / riverV; % modeling river as cylinder 
    riverDia = 2*sqrt(riverCrossArea/pi); % river dia, assume river surface area is 1m x river dia area square.
    riverSA = riverDia;
    
    %Surface Heat Transfer
    duTSurface = surfaceHeatTransfer(solarRad,Tair,uT,Wz,Cp,resArea,newResV,rH); % [°C]
    dlTSurface =  surfaceHeatTransfer(solarRad,Tair,lT,Wz,Cp,riverSA,riverCrossArea,rH); 
    % Considering river depth not to change from resivour flows
    if flowRate >= 0 % case one, flowing up to the upper resivour
        % heat transfer model, river ----> pump -----> resivour
        Qpump = pumpHeatCoff*flowRate*15*60; %[W], 
        Qriv = (lT-uT)*Cp*flowRate*1000*15*60; %[W] considering 15 min intervals
        %disp(["Qpump", Qpump,"Qriv",Qriv])
        Qtotal = Qpump + Qriv;
        %disp(["pump:", Qtotal])
        duTPump = Qtotal/(newResV * 1000 *Cp);
        %disp(["dt Pump", duTPump])
        duT = duTSurface + duTPump;
        dlT = dlTSurface;
    else
        Qturb = turbHeatCoff*-flowRate*15*60;
        Qres = (uT-lT)*Cp*flowRate*1000*15*60;
        disp(["Qturb", Qturb,"Qres",Qres])
        Qtotal = Qturb + Qres;
        %disp(["turb:", Qtotal])
        duTTurb = Qtotal/(riverDischarge*15*60 * 1000 *Cp);
        disp(["dt Pump", duTTurb])
        duT = duTSurface;
        dlT = dlTSurface + duTTurb;
    end
    
    reT = lT + duT; % new res temp
    riT = uT + dlT; % new river temp
    out = [reT,riT,newResV,newDepth];


end


%% ----------------
% 4. Background Functions
%% ----------------
% note, considers 15 minute intervals between
function out = surfaceHeatTransfer(solarRad,Tair,Ts,Wz,Cp,surfaceArea,volume,rH)
    heatExchange = solarRad + surfaceOutput(Tair,Ts,Wz,rH,0.5);
    %disp(["solarRad: ",solarRad, "surfaceEvap", heatExchange - solarRad])
    Q = heatExchange*surfaceArea*60*15;
    out = Q/(volume * 1000 *Cp);
end






function out = resDepthCalc(flowRate,depth,resMaxRadius,resMaxDepth) % changes depth depending on flow rate to deter
    Vder = pi * (resMaxRadius^2)/(resMaxDepth^2) * depth * (2*resMaxDepth - depth);
    out = depth - (flowRate)/Vder;
end
function out = resRadCalc(depth,rMR,rMD)
    out = rMR*sqrt(1 - ((rMD - depth)^2 / rMD^2)); % for whatever reason resMaxRadius is not defined??

end
function out = resAreaCalc(d,rMR,rMD)
    out = pi*(rMR^2) * (1 - ((rMD - d)^2 / rMD^2));
end
function out = resVolumeCalc(d,r)
    out = (4/6)*(r^2)*d*pi;
end
function out = powerOutputSimpleSchedule(hourTime)
    out = 750*cos((pi/12) * hourTime + 14.5);
end